{
    "manifest_version": 3,
    "name": "AI Chat Manager",
    "version": "1.0",
    "description": "Navigate long ChatGPT conversations and delete chats instantly — jump between messages and clean up your sidebar with one click",
    "icons": {
        "16": "icons/icon_16.png",
        "32": "icons/icon_32.png",
        "48": "icons/icon_48.png",
        "128": "icons/icon_128.png"
    },
    "content_scripts": [
        {
            "js": [
                "main.js"
            ],
            "css": [
                "main.css"
            ],
            "matches": [
                "https://chatgpt.com/*"
            ]
        }
    ]
}